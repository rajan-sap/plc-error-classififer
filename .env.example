# Copy to .env (git-ignored, per-developer secrets). Loaded automatically at
# FastAPI startup. The repo runs offline with the mock provider by default.

# Provider: mock | anthropic | google
LLM_PROVIDER=mock

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google (Gemini)
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-3.1-flash-lite-preview
